# LeadFlow AI Service — Environment Variables
# Copy this to .env and fill in your values

# --- LLM Provider ---
# Set to "openai" or leave as "mock" for dev without API key
LEADFLOW_LLM_PROVIDER=mock
# Required if using "openai" provider:
LEADFLOW_OPENAI_API_KEY=
OPENAI_API_KEY=

# --- Server ---
LEADFLOW_HOST=127.0.0.1
LEADFLOW_PORT=8001
LEADFLOW_LOG_LEVEL=info

# --- Email Provider ---
# Options: mock (default), smtp, gmail (placeholder)
LEADFLOW_EMAIL_PROVIDER=mock

# SMTP Configuration (Recommended for production campaigns)
# Common providers:
#   - Gmail: smtp.gmail.com:587 (use App Password, not regular password)
#   - Brevo (Sendinblue): smtp-relay.brevo.com:587
#   - Mailgun, Postmark, Amazon SES, etc.
LEADFLOW_SMTP_HOST=smtp.gmail.com
LEADFLOW_SMTP_PORT=587
LEADFLOW_SMTP_USER=your-email@gmail.com
LEADFLOW_SMTP_PASSWORD=your-app-password-or-smtp-key

# Gmail OAuth2 (for future Gmail API integration — not yet used):
LEADFLOW_GMAIL_CLIENT_ID=
LEADFLOW_GMAIL_CLIENT_SECRET=
